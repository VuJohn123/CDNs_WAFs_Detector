{
  "manifest_version": 3,
  "name": "Multi-CDN/WAF Detector",
  "version": "8.1.0",
  "description": "Detect 21 CDN/WAF/Bot-Management providers via domain or direct IP scan, with PTR/RDAP cross-verification, multi-IP (anycast) inspection, scan history, and hardened scoring against false-positive corroboration.",
  "minimum_chrome_version": "109",
  "permissions": [
    "storage",
    "cookies",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "background": {
    "service_worker": "background.js",
    "scripts": ["background.js"]
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "cdns-wafs-detector@example.com",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html"
  }
}
